# Copy to .env and fill in values
# cp .env.example .env

# ── Optional API keys (pipeline works without them) ──────────────
# Free key from https://newsapi.org (500 req/day)
NEWSAPI_KEY=your_newsapi_key_here

# Free key from https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# Free key from https://www.eia.gov/opendata/
EIA_API_KEY=your_eia_api_key_here

# ── Model settings ────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000
MODEL_NAME=oil_price_ensemble
MODEL_STAGE=Production

# ── API settings ──────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
DASHBOARD_PORT=8501

# ── Forecast settings ─────────────────────────────────────────────
DEFAULT_HORIZON_DAYS=7
LOOKBACK_DAYS=60
CONFIDENCE_LEVEL=0.95

# ── Signal thresholds ─────────────────────────────────────────────
BUY_THRESHOLD=0.60
SELL_THRESHOLD=0.60
STOP_LOSS_PCT=0.025
TAKE_PROFIT_PCT=0.05
